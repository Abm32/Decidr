{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs lint and fixes any errors when a TypeScript file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `npx eslint --fix` on the edited file and fix any remaining lint errors."
  }
}